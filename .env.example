# ── Claude Authentication (choose one) ──────────────────────────────────────

# Option A: Anthropic API key (console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: Claude Pro/Max subscription (run `claude setup-token` to get token)
# CLAUDE_CODE_OAUTH_TOKEN=...

# Option C: AWS Bedrock
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# AWS_SESSION_TOKEN=        # optional, for temporary credentials
# ANTHROPIC_MODEL=          # optional, override model (e.g. us.anthropic.claude-sonnet-4-5-20251001-v1:0)

# ── WhatsApp ─────────────────────────────────────────────────────────────────
ASSISTANT_HAS_OWN_NUMBER=
